<?xml version="1.0" encoding="UTF-8"?>
<gamecontroller configversion="19" appversion="2.24">
    <!--The SDL name for a joystick is included for informational purposes only.-->
    <sdlname>Controller (Xbox One For Windows)</sdlname>
    <!--The GUID for a joystick is included for informational purposes only.-->
    <guid>030000005e040000ff02000000007200</guid>
    <names/>
    <sets>
        <set index="1">
            <stick index="1">
                <diagonalRange>2</diagonalRange>
                <stickbutton index="1">
                    <slots>
                        <slot>
                            <code>0x57</code>
                            <mode>keyboard</mode>
                        </slot>
                    </slots>
                </stickbutton>
                <stickbutton index="3">
                    <slots>
                        <slot>
                            <code>0x44</code>
                            <mode>keyboard</mode>
